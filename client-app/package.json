{
  "name": "toolbox",
  "version": "9.0-SNAPSHOT",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "webpack --env prodBuild",
    "buildAndAnalyze": "webpack --env prodBuild --env analyzeBundles",
    "hoistVer": "cat node_modules/@xh/hoist/package.json | grep version",
    "lint": "npm run lint:all",
    "validateDocs": "node scripts/validate-doc-registry.mjs",
    "lint:all": "npm run lint:code && npm run lint:styles",
    "lint:code": "eslint .",
    "lint:styles": "stylelint \"**/*.s?(a|c)ss\"",
    "prepare": "cd .. && husky client-app/.husky",
    "start": "npm i --prefer-dedupe && cross-env NODE_OPTIONS=--max_old_space_size=3072 webpack-dev-server",
    "startAndAnalyze": "npm run start --env analyzeBundles",
    "startWithIp": "npm run start --env devHost=$(ipconfig getifaddr en0)",
    "startWithHoist": "cd ../../hoist-react && yarn install && cd ../toolbox/client-app && npm i --prefer-dedupe && cross-env NODE_OPTIONS=--max_old_space_size=3072 webpack-dev-server --env inlineHoist",
    "startWithHoistAndAnalyze": "npm run startWithHoist --env analyzeBundles",
    "startWithHoistAndIp": "npm run startWithHoist --env devHost=$(ipconfig getifaddr en0)",
    "startWithHoistSecure": "npm run startWithHoist --env devHttps=true --env devHost=toolbox-local.xh.io"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint"
    ],
    "*.s?(a|c)ss": [
      "prettier --write",
      "stylelint"
    ]
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@ibm/plex-sans": "^1.1.0",
    "@xh/hoist": "^87.0.0-SNAPSHOT",
    "@xh/package-template": "~3.0.1",
    "ag-grid-community": "~35.3.0",
    "ag-grid-enterprise": "~35.3.0",
    "ag-grid-react": "~35.3.0",
    "core-js": "3.x",
    "highcharts": "12.x",
    "lodash": "4.x",
    "minisearch": "^7.1.0",
    "moment": "2.x",
    "react": "~18.2.0",
    "react-dom": "~18.2.0"
  },
  "devDependencies": {
    "@types/react": "18.x",
    "@types/react-dom": "18.x",
    "@xh/hoist-dev-utils": "13.x",
    "cross-env": "10.x",
    "eslint": "10.x",
    "eslint-config-prettier": "10.x",
    "husky": "9.x",
    "lint-staged": "17.x",
    "postcss": "8.x",
    "prettier": "3.x",
    "stylelint": "17.x",
    "stylelint-config-standard-scss": "17.x",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@types/react": "18.x",
    "@types/react-dom": "18.x",
    "@xh/hoist": "^87.0.0-SNAPSHOT",
    "core-js": "3.x"
  }
}
