{
  "compilerOptions": {
    "allowSyntheticDefaultImports":  true,
    "experimentalDecorators": true,
    "jsx": "react",
    "lib": ["dom", "es2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitOverride": true,
    "resolveJsonModule":  true,
    "skipLibCheck": true,
    "target": "ES2022",
    "useDefineForClassFields": true,

    // Inline hoist-react development - commented out by default (see docs/running-locally.md).
    //
    // Left off, `tsc` resolves `@xh/hoist` against the installed published version in
    // node_modules - the same thing CI and the release build check, and what the app actually
    // ships. Enabling it points type-checking at a local sibling checkout instead, which can
    // FALSE-PASS: code using APIs that exist only on the unreleased SNAPSHOT line (e.g. a new prop)
    // type-checks locally but breaks against the released library.
    //
    // Uncomment ONLY while actively developing hoist-react inline (`yarn startWithHoist`) and you
    // need Toolbox to see local type-signature changes. Re-comment before committing - do not
    // commit it enabled.
    //
    // NOTE - deliberately committed ENABLED on this branch: the admin grid tester imports
    // `RecordDataFactory`, new in hoist-react 87 (xh/hoist-react#4500) and not yet available in a
    // published @xh/hoist snapshot. Re-comment once this branch builds against a release that
    // includes it.
    "paths": {
      "@xh/hoist/*": ["../../hoist-react/*"]
    }

  },
  // Reference hoist-react as a composite build.
  // Allows for distinct tsconfig options in hoist-react vs. this application.
  "references": [
    {"path":  "./node_modules/@xh/hoist"}
  ],
  "include": ["src"]
}
